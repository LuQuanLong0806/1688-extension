{
  "manifest_version": 3,
  "name": "电商辅助工具",
  "version": "1.1",
  "description": "电商辅助工具集 - 支持1688图片抓取、店小蜜TEMU辅助等功能",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.svg"
  },
  "icons": {
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["sites/1688/grab-core.js", "sites/1688/float-btn.js"]
    },
    {
      "matches": [
        "*://www.dianxiaomi.com/web/temu/choiceTemuList/draft*",
        "*://www.dianxiaomi.com/web/temu/add*",
        "*://www.dianxiaomi.com/web/temu/edit*"
      ],
      "js": ["sites/dianxiaomi/dxm-config.js", "sites/dianxiaomi/dxm-float-bee.js", "sites/dianxiaomi/dxm-config-ui.js"]
    }
  ]
}
