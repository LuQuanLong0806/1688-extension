{
  "manifest_version": 3,
  "name": "1688图片抓取",
  "version": "1.0",
  "description": "一键抓取1688商品页所有图片，支持主图、详情图、SKU图",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["grab-core.js", "float-btn.js"]
    }
  ]
}
